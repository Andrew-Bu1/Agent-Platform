# ──────────────────────────────────────────────────────────────────
# Agent Studio Service — local development environment
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────────
SERVER_PORT=8082

# ── Database (PostgreSQL) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=agent_studio
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── JWT validation ─────────────────────────────────────────────────
# Set to enforce issuer and audience claims on incoming tokens.
# Leave blank to skip those checks (development default).
JWT_ISSUER=
JWT_AUDIENCE=

# ── Downstream services ────────────────────────────────────────────
# IAM URL is used to fetch the JWKS public key at startup.
# Agent-studio calls GET {IAM_URL}/.well-known/jwks.json to get the RSA public key.
IAM_URL=http://localhost:8080

# AIHub and DataHub are internal services — agent-studio proxies their management APIs
# so the frontend never needs to call them directly.
AIHUB_URL=http://localhost:8083
DATAHUB_URL=http://localhost:8084
