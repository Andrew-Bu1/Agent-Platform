# ──────────────────────────────────────────────────────────────────
# IAM Service — local development environment
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database (PostgreSQL) ──────────────────────────────────────────
# Docker maps host port 5433 → container port 5432
DB_HOST=localhost
DB_PORT=5433
DB_NAME=iam
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── JWT / Signing Key Encryption ───────────────────────────────────
# 32-byte Base64-encoded key used to AES-256-GCM encrypt the private JWK stored in DB.
# Generate with: openssl rand -base64 32
APP_JWT_KEY_ENCRYPTION_SECRET=<CHANGE_ME>

# ── Token TTLs (optional — defaults shown) ─────────────────────────
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800
