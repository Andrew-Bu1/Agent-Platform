# agent-worker environment variables
# Copy to .env and fill in values. Never commit .env.

PORT=8082
WORKER_COUNT=4

# PostgreSQL (agent_studio database — same as agent-orchestrator)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=agent_studio

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_DB=0

# Queue keys (must match agent-orchestrator)
NODE_QUEUE_KEY=agent:queue:node
EVENT_QUEUE_KEY=agent:queue:events
DLQ_KEY=agent:queue:dlq

# AIHub service URL
AIHUB_URL=http://localhost:8000

# JWT auth — IAM JWKS endpoint
IAM_URL=http://localhost:8080
JWT_ISSUER=iam-service
JWT_AUDIENCE=agent-worker
