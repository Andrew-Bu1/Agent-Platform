APP_NAME=aihub
APP_ENV=development
APP_VERSION=1.0.0

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=aihub

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_DB=0

# IAM service for JWKS and entitlement checks
IAM_BASE_URL=http://iam-service:8080

# Local model directory (used by the 'local' adapter for embedding/reranking)
MODEL_DIR=.models

# Fernet key for encrypting provider API keys stored in the DB.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROVIDER_ENCRYPTION_KEY=
