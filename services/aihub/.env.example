APP_NAME=aihub
APP_ENV=development
APP_VERSION=1.0.0

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=aihub

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_DB=0

# IAM service for JWKS and entitlement checks
IAM_BASE_URL=http://iam-service:8080
IAM_ISSUER=iam-service
IAM_AUDIENCE=aihub

# Local model directory (used by the 'local' adapter for embedding/reranking)
MODEL_DIR=.models

# Fernet key for encrypting provider API keys stored in the DB.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROVIDER_ENCRYPTION_KEY=

# MinIO — used to store provider logo images
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aihub
MINIO_SECURE=false
# Public base URL for building object URLs returned to callers.
# In production set this to your CDN or MinIO public endpoint.
MINIO_PUBLIC_URL=http://localhost:9000
